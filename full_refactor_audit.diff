+        });
+      }
+    } catch (error: unknown) {
+      if ((error as Error).name === 'NotAllowedError') {
+        toast.error('Scan cancelled.', { id: 'passkey' });
+      } else {
+        toast.error(`Error: ${(error as Error).message}`, { id: 'passkey' });
+      }
