+                  Set
+                </button>
+              </div>
+            </div>
+
+            {/* DEAD MAN'S SWITCH */}
+            <div className="pt-4 border-t border-white/5 space-y-3 mt-4">
+              <div>
+                <h4 className="text-sm font-bold text-text-primary flex items-center gap-2">
